{
  "manifest_version": 3,
  "name": "ShadowLink",
  "version": "1.0.0",
  "description": "Real-time threat intelligence and phishing detection browser extension.",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "webNavigation",
    "notifications"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "assets/icons/green.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_idle",
      "js": [
        "rules/constants.js",
        "rules/scoring.js",
        "rules/homoglyph.js",
        "rules/domainReputation.js",
        "rules/loginDetector.js",
        "rules/urlAnalyzer.js",
        "rules/urlEntropy.js",
        "rules/urlShortener.js",
        "rules/credentialLeak.js",
        "rules/jsBehavior.js",
        "rules/typosquatting.js",
        "rules/redirectAnalyzer.js",
        "rules/virusTotalCheck.js",
        "core/threatEngine.js",
        "ui/alertUI.js",
        "ui/warningBanner.js",
        "storage/history.js",
        "storage/timelineStore.js",
        "content.js"
      ]
    }
  ]
}
