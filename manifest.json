{
  "manifest_version": 3,

  "name": "ShadowLink",

  "version": "1.0.0",

  "description": "AI-powered phishing detection browser extension.",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "webNavigation",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://*/*",
    "http://*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],

      "run_at": "document_start",

      "js": [

        "rules/scoring.js",

        "core/threatEngine.js",

        "ui/alertUI.js",

        "rules/domainReputation.js",

        "rules/constants.js",

        "rules/homoglyph.js",

        "rules/virusTotalCheck.js",

        "rules/urlAnalyzer.js",

        "rules/loginDetector.js",

        "ui/warningBanner.js",

        "storage/history.js",

        "content.js"
      ]
    }
  ]
}